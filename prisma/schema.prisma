// prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============ USER ==============
model User {
  id        String    @id @default(cuid())
  name      String?
  email     String    @unique
  password  String?
  image     String?
  username  String?   @unique
  isOnline  Boolean   @default(false)
  lastSeen  DateTime?
  provider  String    @default("credentials")
  createdAt DateTime  @default(now())
  updatedAt DateTime @updatedAt

  // AI Chat
  conversations Conversation[]

  // Friends
  sentRequests     Friendship[]    @relation("SentRequests")
  receivedRequests Friendship[]    @relation("ReceivedRequests")

  // DM
  sentMessages     DirectMessage[] @relation("SentMessages")
  receivedMessages DirectMessage[] @relation("ReceivedMessages")

  // Groups
  groupMembers  GroupMember[]
  groupMessages GroupMessage[]
  createdGroups GroupChat[]     @relation("CreatedGroups")

  // Notifications
  notifications Notification[]

  // Blocks
  blockedBy Block[] @relation("BlockedBy")
  blocking  Block[] @relation("Blocking")

  // Subscription
  subscription Subscription?
  payments     Payment[]
  dailyUsage   DailyUsage[]

  @@index([username])
  @@index([email])
}

// =========== AI CHAT ==============
model Conversation {
  id        String   @id @default(cuid())
  title     String   @default("New chat")
  model     String   @default("llama-3.3-70b-versatile")
  pinned    Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  userId   String
  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages Message[]

  @@index([userId])
  @@index([userId, updatedAt(sort: Desc)])
}

model Message {
  id        String   @id @default(cuid())
  role      String
  content   String   @db.Text
  createdAt DateTime @default(now())

  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId])
  @@index([conversationId, createdAt])
}

// =========== FRIENDS =============
model Friendship {
  id        String           @id @default(cuid())
  status    FriendshipStatus @default(PENDING)
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt

  senderId   String
  sender     User   @relation("SentRequests", fields: [senderId], references: [id], onDelete: Cascade)
  receiverId String
  receiver   User   @relation("ReceivedRequests", fields: [receiverId], references: [id], onDelete: Cascade)

  @@unique([senderId, receiverId])
  @@index([receiverId, status])
  @@index([senderId, status])
}

// =========== DIRECT MESSAGES =============
model DirectMessage {
  id        String        @id @default(cuid())
  content   String        @db.Text
  status    MessageStatus @default(SENT)
  createdAt DateTime      @default(now())
  readAt    DateTime?

  // Fix: proper relation syntax
  senderId   String
  sender     User   @relation("SentMessages", fields: [senderId], references: [id], onDelete: Cascade)
  receiverId String
  receiver   User   @relation("ReceivedMessages", fields: [receiverId], references: [id], onDelete: Cascade)

  @@index([senderId, receiverId])
  @@index([receiverId, status])
  @@index([senderId, createdAt(sort: Desc)])
}

// ========== GROUP CHAT ==============
model GroupChat {
  id        String   @id @default(cuid())
  name      String
  avatar    String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  createdById String
  createdBy   User   @relation("CreatedGroups", fields: [createdById], references: [id])

  members  GroupMember[]
  messages GroupMessage[]

  @@index([updatedAt(sort: Desc)])
}

model GroupMember {
  id       String     @id @default(cuid())
  role     MemberRole @default(MEMBER)
  joinedAt DateTime   @default(now())

  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  groupChatId String
  groupChat   GroupChat @relation(fields: [groupChatId], references: [id], onDelete: Cascade)

  @@unique([userId, groupChatId])
  @@index([userId])
  @@index([groupChatId])
}

model GroupMessage {
  id        String   @id @default(cuid())
  content   String   @db.Text
  createdAt DateTime @default(now())

  senderId    String
  sender      User      @relation(fields: [senderId], references: [id])
  groupChatId String
  groupChat   GroupChat @relation(fields: [groupChatId], references: [id], onDelete: Cascade)

  @@index([groupChatId, createdAt(sort: Desc)])
}

// ========== NOTIFICATIONS ==============
model Notification {
  id        String           @id @default(cuid())
  type      NotificationType
  message   String
  read      Boolean          @default(false)
  createdAt DateTime         @default(now())

  // Extra data — jaise friendshipId, messageId etc
  data      String?          @db.Text

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, read])
  @@index([userId, createdAt(sort: Desc)])
}

// ========== BLOCK ==============
model Block {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  blockerId String
  blocker   User   @relation("Blocking", fields: [blockerId], references: [id], onDelete: Cascade)
  blockedId String
  blocked   User   @relation("BlockedBy", fields: [blockedId], references: [id], onDelete: Cascade)

  @@unique([blockerId, blockedId])
  @@index([blockerId])
  @@index([blockedId])
}

// ========== ENUMS ==========
enum FriendshipStatus {
  PENDING
  ACCEPTED
  BLOCKED
}

enum MessageStatus {
  SENT
  DELIVERED
  READ
}

enum MemberRole {
  ADMIN
  MODERATOR
  MEMBER
}

enum NotificationType {
  FRIEND_REQUEST
  FRIEND_ACCEPTED
  FRIEND_REJECTED
  NEW_MESSAGE
  GROUP_INVITE
}


model Subscription {
  id        String           @id @default(cuid())
  plan      PlanType             @default(FREE)
  status    SubscriptionStatus   @default(ACTIVE)
  startDate DateTime             @default(now())
  endDate   DateTime?
  createdAt DateTime            @default(now())
  updatedAt DateTime            @updatedAt

  userId   String              @unique
  user     User                @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Payment {
  id              String        @id @default(cuid())
  amount          Int           // Paise mein — 29900 = ₹299
  currency        String        @default("INR")
  status          PaymentStatus @default(CREATED)
  razorpayOrderId String?       @unique
  razorpayPayId   String?       @unique
  plan            PlanType
  createdAt       DateTime      @default(now())

  userId         String
  user           User          @relation(fields: [userId], references: [id])

  @@index([userId])
}

model DailyUsage {
  id        String       @id @default(cuid())
  date      String   // "2026-04-05" format
  count     Int          @default(0)
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  userId   String
  user     User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date])
  @@index([userId, date])
}

enum PlanType {
  FREE
  PRO
  ENTERPRISE
}

enum SubscriptionStatus {
  ACTIVE
  EXPIRED
  CANCELLED
}

enum PaymentStatus {
  CREATED
  PAID
  FAILED
  REFUNDED
} 